# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Public URLs (SMS links, CORS in production)
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://verifiedvote:verifiedvote@localhost:5432/verifiedvote
DB_CONNECT_TIMEOUT_MS=30000
DB_IDLE_TIMEOUT_MS=20000
DB_POOL_MAX=10
PGCRYPTO_KEY=change-me-32-chars-minimum

# Optional DB startup retry for cron jobs
# DB_STARTUP_MAX_ATTEMPTS=0
# DB_STARTUP_RETRY_MS=10000

# ── JWT signing (min 32 chars; stable across restarts) ───────────────────────
VOTER_JWT_SECRET=change-me-voter-jwt-secret-min-32-chars
ADMIN_JWT_SECRET=change-me-admin-jwt-secret-min-32-chars
SESSION_JWT_SECRET=change-me-session-jwt-secret-min-32-chars

# ── Admin seed (used by seed:admins) ─────────────────────────────────────────
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=change-me
REVIEWER_USERNAME=reviewer
REVIEWER_PASSWORD=change-me

# ── Voter ID verification ─────────────────────────────────────────────────────
# mock = local voter_roll.json | protean = stub
VOTER_VERIFY_MODE=mock

# ── AI face service ───────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TIMEOUT_MS=10000

# ── SMS (TextBee) ─────────────────────────────────────────────────────────────
SMS_PROVIDER=textbee
TEXTBEE_API_KEY=
TEXTBEE_DEVICE_ID=

# ── MinIO object storage ──────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=verifiedvote-docs
MINIO_USE_SSL=false

# ── Cloudflare Turnstile (server-side secret) ─────────────────────────────────
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# ── Docker entrypoint ─────────────────────────────────────────────────────────
# RUN_MIGRATIONS=true
# SEED_ADMINS=false

# ── Optional maintenance ──────────────────────────────────────────────────────
# ENABLE_AUDIT_LOG_PURGE=true
