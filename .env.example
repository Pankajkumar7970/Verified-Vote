DATABASE_URL=postgresql://user:pass@localhost:5432/verifiedvote
# Neon: use the pooler host (*-pooler.*.neon.tech) and allow 30s+ for cold start
DB_CONNECT_TIMEOUT_MS=30000
DB_IDLE_TIMEOUT_MS=20000
DB_POOL_MAX=10
PGCRYPTO_KEY=change-me-32-chars-minimum

# JWT signing keys (min 32 chars). Use stable values across restarts or sessions invalidate.
# JWT_SECRET is a legacy fallback if the role-specific secrets below are unset.
JWT_SECRET=change-me-jwt-secret-min-32-chars-long
VOTER_JWT_SECRET=change-me-jwt-secret-min-32-chars-long
ADMIN_JWT_SECRET=change-me-jwt-secret-min-32-chars-long
SESSION_JWT_SECRET=change-me-jwt-secret-min-32-chars-long

SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=change-me
REVIEWER_USERNAME=reviewer
REVIEWER_PASSWORD=change-me

# mock = local voter_roll.json | protean = stub (not implemented for production)
VOTER_VERIFY_MODE=mock

AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TIMEOUT_MS=10000

# SMS: TextBee is implemented; MSG91 adapter is not yet built.
SMS_PROVIDER=textbee
TEXTBEE_API_KEY=
TEXTBEE_DEVICE_ID=

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=verifiedvote-docs
MINIO_USE_SSL=false

# Cloudflare Turnstile (use 1x0000000000000000000000000000000AA for testing)
# Get keys from https://dash.cloudflare.com -> Turnstile
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3000
PORT=3000
NODE_ENV=development

# Optional: delete audit_logs older than 1 year (default off — see ARCHITECTURE.md)
# ENABLE_AUDIT_LOG_PURGE=true
