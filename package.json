{
  "name": "VerifiedVote",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --target=es2022 --outfile=dist/server.js --format=esm --external:express --external:pg --external:bcrypt --external:jsonwebtoken --external:minio",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "preview": "npm run build && wrangler dev",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "cross-env NODE_ENV=test tsx --test backend/src/utils/ref-code.test.ts",
    "test:integration": "cross-env NODE_ENV=test tsx --test backend/src/test/integration.test.ts",
    "migrate": "node-pg-migrate",
    "seed:admins": "tsx backend/src/db/seed/admin.seed.ts",
    "db:keep-alive": "tsx backend/src/cron/keep-db-alive.ts",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.5.2",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.100.10",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.16.0",
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dompurify": "^3.4.2",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.2.0",
    "i18next": "^26.1.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "minio": "^8.0.5",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^17.0.7",
    "react-router-dom": "^7.15.0",
    "sanitize-html": "^2.17.3",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.0",
    "@playwright/test": "^1.60.0",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "esbuild": "^0.28.0",
    "node-pg-migrate": "^8.0.4",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "wrangler": "^4.98.0"
  }
}
