# Copy to .env before: docker compose -f docker-compose.prod.yml up -d --build

# ── Public URLs (must match how users reach the app) ─────────────────────────
FRONTEND_URL=https://your-domain.example
APP_URL=https://your-domain.example
APP_PORT=3000

# ── Postgres (docker-compose.prod internal service) ──────────────────────────
POSTGRES_USER=verifiedvote
POSTGRES_PASSWORD=change-me-strong-postgres-password
POSTGRES_DB=verifiedvote
DATABASE_URL=postgres://verifiedvote:change-me-strong-postgres-password@postgres:5432/verifiedvote

DB_CONNECT_TIMEOUT_MS=30000
DB_IDLE_TIMEOUT_MS=20000
DB_POOL_MAX=10

# ── Crypto & JWT (generate with: openssl rand -hex 32) ───────────────────────
PGCRYPTO_KEY=change-me-32-chars-minimum-secret
VOTER_JWT_SECRET=change-me-voter-jwt-min-32-chars-long-secret
ADMIN_JWT_SECRET=change-me-admin-jwt-min-32-chars-long-secret
SESSION_JWT_SECRET=change-me-session-jwt-min-32-chars-long-secret

# ── Admin seed (first deploy: SEED_ADMINS=true on app container) ─────────────
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=change-me-strong-admin-password
REVIEWER_USERNAME=reviewer
REVIEWER_PASSWORD=change-me-strong-reviewer-password
SEED_ADMINS=false

# ── Voter verification ───────────────────────────────────────────────────────
VOTER_VERIFY_MODE=mock

# ── AI service (compose sets AI_SERVICE_URL to http://ai-service:8000) ───────
AI_SERVICE_TIMEOUT_MS=10000

# ── MinIO (compose sets MINIO_ENDPOINT=minio) ────────────────────────────────
MINIO_ACCESS_KEY=change-me-minio-access-key
MINIO_SECRET_KEY=change-me-minio-secret-key-min-16-chars
MINIO_BUCKET_NAME=verifiedvote-docs
MINIO_PORT=9000
MINIO_USE_SSL=false

# ── SMS (TextBee) ────────────────────────────────────────────────────────────
SMS_PROVIDER=textbee
TEXTBEE_API_KEY=
TEXTBEE_DEVICE_ID=

# ── Cloudflare Turnstile (production keys from dash.cloudflare.com) ──────────
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
RUN_MIGRATIONS=true
